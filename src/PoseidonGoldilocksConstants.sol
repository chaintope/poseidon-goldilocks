pragma solidity ^0.8.24;

/// @notice All Poseidon-Goldilocks constants (plonky2 rev 109d517d), incl. the fast-partial-round
///         tables. Auto-generated; do NOT hand-edit. Layouts:
///           ARC[12*round + lane] (360); FIRST[12]; RC22[22];
///           VS[i*11 + (k-1)] and WHATS[i*11 + (k-1)] (22 rounds x 11); INIT[(r-1)*11 + (c-1)] (11x11).
struct PoseidonConstants {
    uint256[360] arc;
    uint256[12]  first;
    uint256[22]  rc22;
    uint256[242] vs;
    uint256[242] whats;
    uint256[121] initMat;
}

library PoseidonGoldilocksConstants {
    bytes constant ARC_PACKED = hex"";
    function _loadARC(uint256 ptr) private pure {
        bytes memory p = ARC_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 360) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }
    bytes constant FIRST_PACKED = hex"3cc3f892184df408e993fd841e7e97f1f2831d3575f0f3afd2500e0a350994cac5571f35d728863391d89c5184109a02f37f925d04e5667b2d6e448371955a69740ef19ce01398a1694d24c0752fdf4560936af96ee2f148c33448feadc78f0c";
    function _loadFIRST(uint256 ptr) private pure {
        bytes memory p = FIRST_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 12) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }
    bytes constant RC22_PACKED = hex"";
    function _loadRC22(uint256 ptr) private pure {
        bytes memory p = RC22_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 22) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }
    bytes constant VS_PACKED = hex"";
    function _loadVS(uint256 ptr) private pure {
        bytes memory p = VS_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 242) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }
    bytes constant WHATS_PACKED = hex"";
    function _loadWHATS(uint256 ptr) private pure {
        bytes memory p = WHATS_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 242) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }
    bytes constant INIT_PACKED = hex"";
    function _loadINIT(uint256 ptr) private pure {
        bytes memory p = INIT_PACKED;
        assembly { let src := add(p, 32) for { let i := 0 } lt(i, 121) { i := add(i,1) } {
            mstore(add(ptr, mul(i, 32)), shr(192, mload(add(src, mul(i, 8)))))
        } }
    }

    /// @notice Backward-compatible: just the 360 round constants.
    function arc() internal pure returns (uint256[360] memory out) {
        uint256 ptr; assembly { ptr := out } _loadARC(ptr);
    }

    /// @notice Load every Poseidon constant once (amortise across a whole tree path).
    function load() internal pure returns (PoseidonConstants memory c) {
        uint256 p0; assembly { p0 := mload(c) }            _loadARC(p0);
        uint256 p1; assembly { p1 := mload(add(c, 0x20)) } _loadFIRST(p1);
        uint256 p2; assembly { p2 := mload(add(c, 0x40)) } _loadRC22(p2);
        uint256 p3; assembly { p3 := mload(add(c, 0x60)) } _loadVS(p3);
        uint256 p4; assembly { p4 := mload(add(c, 0x80)) } _loadWHATS(p4);
        uint256 p5; assembly { p5 := mload(add(c, 0xa0)) } _loadINIT(p5);
    }
}
